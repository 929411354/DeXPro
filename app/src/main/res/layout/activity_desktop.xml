<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/desktopRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Desktop workspace area (app windows rendered here) -->
    <FrameLayout
        android:id="@+id/workspaceContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/taskbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Widget grid (background layer) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <com.dexpro.launcher.widget.WidgetGridLayout
                android:id="@+id/widgetGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:columnCount="4"
                android:orientation="horizontal" />
        </ScrollView>

        <!-- Desktop shortcuts (overlay layer, at top) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/desktopShortcuts"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:paddingTop="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false" />
    </FrameLayout>

    <!-- Taskbar -->
    <include
        android:id="@+id/taskbar"
        layout="@layout/taskbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Start Menu overlay -->
    <include
        android:id="@+id/startMenu"
        layout="@layout/start_menu"
        android:layout_width="360dp"
        android:layout_height="480dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/taskbar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- System Tray popup -->
    <include
        android:id="@+id/systemTray"
        layout="@layout/system_tray"
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/taskbar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Window resize overlay guide -->
    <View
        android:id="@+id/resizeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#00000000" />

</androidx.constraintlayout.widget.ConstraintLayout>
