<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Animation & Visuals -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Animation &amp; Visuals"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Animation duration" />
                <TextView
                    android:id="@+id/tvAnimationDurationValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="250ms" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/sliderAnimationDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progress="250" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Snap threshold" />
                <TextView
                    android:id="@+id/tvSnapThresholdValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50px" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/sliderSnapThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="50" />

            <Switch
                android:id="@+id/swShowShadows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show window shadows"
                android:layout_marginTop="16dp" />

            <Switch
                android:id="@+id/swShowBorders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show window borders"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Grid & Tiling -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grid &amp; Tiling"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Grid columns" />
                <TextView
                    android:id="@+id/tvGridColumnsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/sliderGridColumns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10"
                android:progress="4" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Grid rows" />
                <TextView
                    android:id="@+id/tvGridRowsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/sliderGridRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10"
                android:progress="3" />

            <Switch
                android:id="@+id/swAutoTile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-tile new windows"
                android:layout_marginTop="16dp" />

        </LinearLayout>

        <!-- Input & Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Input &amp; Controls"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gesture sensitivity" />
                <TextView
                    android:id="@+id/tvGestureSensitivityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="50" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/sliderGestureSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50" />

            <Switch
                android:id="@+id/swKeyboardShortcuts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable keyboard shortcuts"
                android:layout_marginTop="16dp" />

            <Switch
                android:id="@+id/swMouseAcceleration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable mouse acceleration"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Plugins & Extensions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plugins &amp; Extensions"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <Switch
                android:id="@+id/swPluginAutoUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto-update plugins"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnPluginManager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plugin Manager"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnKeymapEditor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Keymap Editor"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnGestureEditor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gesture Editor"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Debug & Advanced -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Debug &amp; Advanced"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <Switch
                android:id="@+id/swDebugOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show debug overlay"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnResetDefaults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset to Defaults"
                android:layout_marginTop="24dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>