<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/startMenuRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_start_menu"
    android:elevation="16dp">

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/surfaceVariant">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="Type to search apps..."
            android:textColorHint="#666"
            android:textColor="@color/onSurface"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Pinned apps section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pinned"
        android:textColor="#888"
        android:textSize="11sp"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:textAllCaps="true"
        android:letterSpacing="0.1" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pinnedAppsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/windowBorder"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- All apps list -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All Apps"
        android:textColor="#888"
        android:textSize="11sp"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textAllCaps="true"
        android:letterSpacing="0.1" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/allAppsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

    <!-- Bottom: user / power -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/surfaceVariant">

        <ImageButton
            android:id="@+id/btnUser"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_person"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnPower"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_power"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>
</LinearLayout>
